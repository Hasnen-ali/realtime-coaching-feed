NODE_ENV=development
PORT=5000

# Use a local MongoDB instance, MongoDB Atlas URL, or a Docker service URL.
MONGODB_URI=mongodb://127.0.0.1:27017/coaching-feed

# Redis is optional at runtime; the API falls back to MongoDB if Redis is unavailable.
REDIS_URL=redis://127.0.0.1:6379
FEED_CACHE_TTL_SECONDS=60

# Comma-separated list of allowed frontend origins.
CLIENT_ORIGIN=http://localhost:3000

# Basic API protection for high-volume endpoints.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
